# ============================================
# DARK013TATTOO - .gitignore
# ============================================

# 🔐 Variáveis de ambiente e credenciais
.env
.env.local
.env.production
*.key
*.pem
*.crt
config-secreto.json
supabase-credentials.json

# 🗄️ Backups locais (podem conter dados sensíveis)
backup_*.json
export_*.json
dados-locais/

# 📦 Dependências e build
node_modules/
dist/
build/
*.min.js
*.map

# 🖥️ Sistema operacional
.DS_Store
Thumbs.db
desktop.ini
*.log
.tmp/
.temp/

# 🌐 IDEs e editores
.vscode/
.idea/
*.swp
*.swo
*~

# 🧪 Testes e cobertura
coverage/
.nyc_output/

# 🚫 Nunca commitar:
# - Chaves de API do Supabase (SERVICE_ROLE)
# - Senhas de banco de dados
# - Tokens de autenticação
# - Arquivos com dados reais de clientes
